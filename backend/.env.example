# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
# Leave blank to run in dev mode (no auth, single shared user)
CLERK_ISSUER_URL=https://your-instance.clerk.accounts.dev

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to local SQLite. For production use Postgres or Turso.
# DATABASE_URL=sqlite:///./tickrprowl.db
# DATABASE_URL=postgresql://user:pass@host/dbname

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL
FRONTEND_URL=https://your-app.vercel.app

# ── Telegram alerts (optional) ────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
